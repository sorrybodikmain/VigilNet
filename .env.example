# ═════════════════════════════════════════════════════════════════════════════
# VigilNet — Multi-Camera Person Tracker
# Copy this file to .env and fill in your values.
# ═════════════════════════════════════════════════════════════════════════════

# ── Camera 1 ─────────────────────────────────────────────────────────────────
CAM1_NAME=Camera1
CAM1_IP=192.168.1.10
CAM1_USER=admin
CAM1_PASSWORD=yourpassword
CAM1_RTSP_4K=rtsp://admin:yourpassword@192.168.1.10:554/user=admin&password=yourpassword&stream=0.sdp
CAM1_RTSP_SD=rtsp://admin:yourpassword@192.168.1.10:554/user=admin&password=yourpassword&stream=1.sdp
CAM1_ONVIF_PORT=80

# ── Camera 2 ─────────────────────────────────────────────────────────────────
CAM2_NAME=Camera2
CAM2_IP=192.168.1.11
CAM2_USER=admin
CAM2_PASSWORD=yourpassword
CAM2_RTSP_4K=rtsp://admin:yourpassword@192.168.1.11:554/user=admin&password=yourpassword&stream=0.sdp
CAM2_RTSP_SD=rtsp://admin:yourpassword@192.168.1.11:554/user=admin&password=yourpassword&stream=1.sdp
CAM2_ONVIF_PORT=80

# ── Camera 3 ─────────────────────────────────────────────────────────────────
CAM3_NAME=Camera3
CAM3_IP=192.168.1.12
CAM3_USER=admin
CAM3_PASSWORD=yourpassword
CAM3_RTSP_4K=rtsp://admin:yourpassword@192.168.1.12:554/user=admin&password=yourpassword&stream=0.sdp
CAM3_RTSP_SD=rtsp://admin:yourpassword@192.168.1.12:554/user=admin&password=yourpassword&stream=1.sdp
CAM3_ONVIF_PORT=80

# ── Yard dimensions (meters) ─────────────────────────────────────────────────
YARD_WIDTH_M=40
YARD_HEIGHT_M=60

# ── Tracking ─────────────────────────────────────────────────────────────────
DETECTION_CONFIDENCE=0.5
REID_THRESHOLD=0.72
PTZ_SMOOTHING=0.25
MAX_LOST_FRAMES=45
FRAME_SKIP=2
YOLO_MODEL=yolov8n.pt

# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8765
FRONTEND_PORT=80

CONFIG_PATH=/app/config/camtrack_config.json
MODEL_CACHE=/app/models
