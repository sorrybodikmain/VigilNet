# ═════════════════════════════════════════════════════════════════════════════
# CamTrack — infrastructure config
# Camera data is stored in PostgreSQL (added via UI → CAMERAS tab → SAVE)
# ═════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=camtrack
DB_USER=camtrack
DB_PASSWORD=camtrack

# ── Tracking ─────────────────────────────────────────────────────────────────
DETECTION_CONFIDENCE=0.5
REID_THRESHOLD=0.72
PTZ_SMOOTHING=0.25
MAX_LOST_FRAMES=45
FRAME_SKIP=2
YOLO_MODEL=yolov8n.pt

# ── PTZ ───────────────────────────────────────────────────────────────────────
PTZ_HOLD_SECONDS=30
PTZ_MANUAL_TIMEOUT=15

# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8765
FRONTEND_PORT=80
PGADMIN_PORT=5050

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ── Paths ────────────────────────────────────────────────────────────────────
MODEL_CACHE=/app/models
